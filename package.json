{
  "name": "celery-launcher",
  "version": "2.4.2",
  "description": "A fast, minimal Minecraft launcher for PvP and SMP — by Celery",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:all": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.celerylauncher.app",
    "productName": "Celery Launcher",
    "copyright": "Copyright © 2026 Celery",
    "icon": "assets/icon.ico",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "executableName": "CeleryLauncher"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Celery Launcher",
      "deleteAppDataOnUninstall": false,
      "include": "installer.nsh"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "asar": true,
    "compression": "normal",
    "publish": [
      {
        "provider": "github",
        "owner": "Celery-codes",
        "repo": "celery-launcher"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "node-fetch": "^2.7.0",
    "open": "^9.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "author": "Celery"
}
