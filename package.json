{
  "name": "celery-launcher",
  "version": "2.1.0",
  "description": "A fast, minimal Minecraft launcher for PvP and SMP \u2014 by Celery",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:all": "electron-builder -mwl",
    "update": "node scripts/apply-update.js"
  },
  "build": {
    "appId": "com.celerylauncher.app",
    "productName": "Celery Launcher",
    "copyright": "Copyright \u00a9 2026 Celery",
    "icon": "assets/icon.ico",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Celery Launcher"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "asar": true,
    "compression": "maximum"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "extract-zip": "^2.0.1",
    "node-fetch": "^2.7.0",
    "open": "^9.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0"
  },
  "author": "Celery"
}